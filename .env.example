# Supabase — 在 supabase.com 项目 Settings → API 中获取
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key（仅服务端使用，不暴露到客户端）
SUPABASE_SERVICE_ROLE_KEY=

# ─── P5-SY9J: Web 真实写入功能门 ──────────────────────────
# true = 启用 Web 真实写入入口；false = 仅允许 Dry Run
# 生产启用需用户明确授权。不启用时 triggerBatchRealWrite 返回 feature gate 错误。
WEBSYNC_REAL_WRITE_ENABLED=false

# ─── P5-SY10E: Vercel Cron 定时任务 ──────────────────────────

# Vercel Cron 路由鉴权 API key（由用户自行生成安全随机字符串）
CRON_API_KEY=

# 定时任务触发时使用的系统用户 UUID（Supabase auth.users 中的 Admin 用户）
CRON_SYSTEM_USER_ID=

# ─── P3-S1B: 百世开放平台 API ──────────────────────────────
# 百世开放平台只读 API 凭证（仅服务端，不暴露到客户端）
BEST_OPEN_BASE_URL=
BEST_OPEN_PARTNER_ID=
BEST_OPEN_SECRET=
